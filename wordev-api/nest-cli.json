{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "src",
  "compilerOptions": {
    "deleteOutDir": true,
    "assets": [
      {
        "include": "../prisma/generated/package.json",
        "outDir": "./dist/prisma",
        "flat": false
      }
    ],
    "watchAssets": true
  }
}
